{
  "name": "pridicta-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev:mobile": "pnpm --filter @pridicta/mobile start",
    "dev:web": "pnpm --filter @pridicta/web dev",
    "build:mobile": "pnpm --filter @pridicta/mobile build:android",
    "build:web": "pnpm --filter @pridicta/web build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:charts": "pnpm --filter @pridicta/astrology stress:charts",
    "test:numerology": "node scripts/run-numerology-foundation-model.mjs",
    "test:nav-new-rooms": "node scripts/run-nav-and-new-rooms-qa-gate.mjs",
    "test:discipline-handoff": "node scripts/run-discipline-handoff-contract.mjs",
    "test:signature-report": "node scripts/run-signature-report-synthesis.mjs",
    "test:buyer-rejection": "node scripts/run-end-to-end-buyer-rejection-test.mjs",
    "test:pdf-golden": "node scripts/run-pdf-report-golden-output-gate.mjs",
    "test:predicta-context": "node scripts/run-predicta-context-reliability-suite.mjs",
    "test:public-greenlight": "node scripts/run-public-testing-greenlight-audit.mjs",
    "test:visual-proof": "node scripts/run-mobile-tablet-visual-proof-gate.mjs",
    "test:mobile": "pnpm --filter @pridicta/mobile exec jest --runInBand",
    "test:web": "pnpm --filter @pridicta/web test",
    "mobile:android": "pnpm --filter @pridicta/mobile android",
    "mobile:bundle:android": "pnpm --filter @pridicta/mobile bundle:android"
  },
  "devDependencies": {
    "turbo": "^2.6.1",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": "0.8.13",
      "fast-xml-parser": "5.7.0",
      "postcss": "8.5.10"
    }
  }
}
